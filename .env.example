# Supabase project URL (Settings -> API -> Project URL)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# Supabase service role key (Settings -> API -> service_role -- red "secret" badge).
# Server-only; never expose to the browser.
# IMPORTANT: must be the service-role key, NOT the anon key. Decode the JWT at
# jwt.io -- the body should show "role":"service_role". If it shows
# "role":"anon", writes will silently produce 0 rows whenever RLS is enabled.
SUPABASE_SERVICE_ROLE_KEY=eyJh...

# Port for the local Express API (default 3001). Not used by Vercel.
PORT=3001
